# ─── 数据库 ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://creativeos:creativeos@127.0.0.1:5432/creativeos?schema=public

# ─── 会话 ───────────────────────────────────────────────────────
# 生产环境必须设置固定密钥，建议使用 32 字节以上随机字符串。
AUTH_SESSION_SECRET=

# 可选：模型凭据加密密钥。生产环境建议单独设置 32 字节以上随机字符串。
# 不设置时会回退使用 AUTH_SESSION_SECRET。
CANVAS_MODEL_CREDENTIAL_SECRET=

# ─── 后台任务 ───────────────────────────────────────────────────
# 用于保护定时清理接口 /api/canvas/assets/cleanup。
CANVAS_CLEANUP_TOKEN=
# 用于保护后台任务执行接口 /api/canvas/tasks/run。
CANVAS_TASK_WORKER_TOKEN=

# ─── 画布资产存储 ───────────────────────────────────────────────
# 支持 local / s3 / r2。R2 使用 S3 兼容配置。
CANVAS_ASSET_STORAGE_DRIVER=local
# 可选：生产环境如果通过 CDN 或反向代理暴露 /uploads/canvas-assets，可填写公开域名。
CANVAS_ASSET_PUBLIC_BASE_URL=
# S3/R2 对象存储配置，仅当 CANVAS_ASSET_STORAGE_DRIVER=s3 或 r2 时需要。
CANVAS_ASSET_S3_ENDPOINT=
CANVAS_ASSET_S3_REGION=auto
CANVAS_ASSET_S3_BUCKET=
CANVAS_ASSET_S3_ACCESS_KEY_ID=
CANVAS_ASSET_S3_SECRET_ACCESS_KEY=

# ─── 记忆向量 ───────────────────────────────────────────────────
# 默认 local：使用本地 hash 向量，开发和无外部模型时可用。
# 设置为 model_gateway 后，通过 OpenAI/OpenAI-compatible /embeddings 生成真实向量。
CANVAS_MEMORY_EMBEDDING_DRIVER=local
CANVAS_MEMORY_EMBEDDING_PROVIDER_TYPE=openai_compatible
CANVAS_MEMORY_EMBEDDING_BASE_URL=
CANVAS_MEMORY_EMBEDDING_API_KEY=
CANVAS_MEMORY_EMBEDDING_MODEL=

# ─── Agent Strategy ──────────────────────────────────────────────
# "mock" | "dify"
AGENT_STRATEGY=mock

# ─── Dify Configuration (required when AGENT_STRATEGY=dify) ─────
DIFY_API_KEY=
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_WORKFLOW_CREATE_CHARACTER=
DIFY_WORKFLOW_CREATE_SKELETON=
DIFY_WORKFLOW_CREATE_ANIMATION=
DIFY_WORKFLOW_CREATE_PREVIEW=

# ─── Model Gateway Providers ─────────────────────────────────────
# Set API keys for providers you want to enable.
# Models are configured in src/services/model/providers.config.json

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Ollama (local — no API key needed, but can be set if required)
OLLAMA_API_KEY=not-needed
